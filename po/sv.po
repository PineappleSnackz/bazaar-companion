#: src/extension.js:61
msgid "App Details"
msgstr "Programdetaljer"

#: src/extension.js:81 src/removeDialog.js:404
msgid "Uninstall"
msgstr "Avinstallera"

#: src/removeDialog.js:320
msgid "Keep Data"
msgstr "Behåll data"

#: src/removeDialog.js:321
msgid "Allow restoring settings and content"
msgstr "Möjliggör återställning av inställningar och innehåll"

#: src/removeDialog.js:328
msgid "Delete Data"
msgstr "Ta bort data"

#: src/removeDialog.js:329
msgid "Permanently remove app data to save space"
msgstr "Tar bort appdata permanent för att spara utrymme"

#: src/removeDialog.js:346
msgid "Cancel"
msgstr "Avbryt"

#: src/removeDialog.js:376
msgid "this app"
msgstr "denna app"

#: src/removeDialog.js:384
msgid "Cannot Uninstall App"
msgstr "Det gick inte att avinstallera appen"

#: src/removeDialog.js:385
#, javascript-format
msgid "%s does not appear to be installed as a Flatpak."
msgstr "%s verkar inte vara installerad som en Flatpak."

#: src/removeDialog.js:393 src/removeDialog.js:402
#, javascript-format
msgid "Remove %s?"
msgstr "Ta bort %s?"

#: src/removeDialog.js:394
#, javascript-format
msgid "%s is installed in multiple locations. Please use Bazaar to manage it."
msgstr "%s är installerad på flera platser. Använd Bazaar för att hantera appen."

#: src/removeDialog.js:395
msgid "OK"
msgstr "Ok"

#: src/removeDialog.js:403
#, javascript-format
msgid "It will not be possible to use %s after it is uninstalled."
msgstr "Det går inte att använda %s efter att appen har avinstallerats."

#: src/removeDialog.js:419
#, javascript-format
msgid "%s Uninstalled"
msgstr "%s avinstallerad"

#: src/removeDialog.js:420
#, javascript-format
msgid "%s was successfully removed."
msgstr "%s avinstallerades."

#: src/removeDialog.js:425
#, javascript-format
msgid "Failed to Remove %s"
msgstr "Borttagning av %s misslyckades"

#: src/removeDialog.js:426
#, javascript-format
msgid "Could not uninstall %s. Try using Bazaar instead."
msgstr "Det gick inte att avinstallera %s. Prova att använda Bazaar i stället."
